APP_NAME=Starfish Backend
APP_VERSION=0.1.0
APP_DESCRIPTION=Starfish backend skeleton for domain map, reading list, gap finder and lineage APIs.
CORS_ORIGINS=http://localhost:17327,http://127.0.0.1:17327,http://localhost:5173,http://127.0.0.1:5173

# OpenAI-compatible LLM
API_KEY=
DASHSCOPE_API_KEY=
OPENAI_MODEL=qwen3.5-plus
EMBEDDING_MODEL=text-embedding-v3
OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# External API Keys (optional in skeleton)
SEMANTIC_SCHOLAR_API_KEY=
OPENALEX_MAILTO=
SCITE_API_KEY=
GITHUB_TOKEN=

# Data Layer (docker defaults)
POSTGRES_DSN=postgresql://starfish:starfish@postgres:5432/starfish
NEO4J_URI=bolt://neo4j:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=starfish
REDIS_URL=redis://redis:6379/0

# Runtime
HTTP_TIMEOUT_SECONDS=10
TASK_PROGRESS_STEP_SECONDS=0.2
GRAPHRAG_FORCE_MOCK=false
ENABLE_LANDSCAPE_SUMMARY=false
